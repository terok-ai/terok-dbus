# Podman stable (Fedora rawhide-based) — tests unexpected env setups
FROM quay.io/podman/stable:latest

RUN dnf install -y \
    dbus \
    gcc python3-devel dbus-devel glib2-devel pkgconf meson \
    python3 python3-pip \
    git curl \
    && dnf clean all

RUN useradd -m podman
WORKDIR /src
